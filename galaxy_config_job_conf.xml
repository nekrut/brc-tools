<?xml version="1.0"?>
<job_conf>
  <plugins>
    <plugin id="local" type="runner" load="galaxy.jobs.runners.local:LocalJobRunner" workers="4"/>
  </plugins>
  <destinations default="docker_heavy">
    <destination id="local" runner="local"/>
    <destination id="docker_heavy" runner="local">
      <param id="docker_enabled">true</param>
      <param id="docker_sudo">false</param>
      <param id="docker_volumes">$defaults</param>
      <param id="docker_set_user">$UID</param>
      <env id="GALAXY_SLOTS">16</env>
      <env id="GALAXY_MEMORY_MB">61440</env>
      <resubmit condition="memory_limit_reached" destination="docker_heavy"/>
    </destination>
  </destinations>
  <tools>
    <tool id="upload1" destination="local"/>
    <tool id="__DATA_FETCH__" destination="local"/>
    <tool id="cat1" destination="local"/>
    <tool id="__FLATTEN__" destination="local"/>
    <tool id="__MERGE_COLLECTION__" destination="local"/>
    <tool id="pansn_rename" destination="local"/>
    <tool id="fasta_concat" destination="local"/>
  </tools>
</job_conf>
